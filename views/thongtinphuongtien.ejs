<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>myCARe - Thông tin phương tiện</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Modak&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    /* ===== Layout Styles ===== */
    body { margin: 0; font-family: 'Arial', sans-serif; background: #f0f2f5; overflow: auto; }
    .left-panel { position: fixed; top: 0; left: 0; width: 320px; height: 100vh; background: #fff; z-index: 1002; border-right: 1px solid #e6e9ee; padding: 24px; box-shadow: 2px 0 8px rgba(15,23,42,0.04); }
    .main-content { position: absolute; top: 0; left: 320px; width: calc(100% - 320px); min-height: 100vh; padding: 24px; display: flex; flex-direction: column; }
    .top-bar { display: flex; justify-content: flex-end; padding: 8px 0; margin-bottom: 20px; }

    /* ===== Logo & Navigation ===== */
    .left-panel .logo { font-family: 'Modak', cursive; font-size: 36px; background: linear-gradient(90deg, #1a73e8, #03f007); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: 3px; }
    .left-panel .desc { color: #6b7280; font-size: 15px; line-height: 1.5; margin: 16px 0; }
    .nav-btn { background: #1a73e8; border: none; padding: 10px 20px; margin: 0 8px; color: #fff; font-size: 15px; border-radius: 6px; cursor: pointer; transition: all 0.2s; text-decoration: none; }
    .nav-btn:hover { background: #1557b0; transform: translateY(-1px); }

    /* ===== Card Styles ===== */
    .card { width: 100%; background: #fff; border-radius: 12px; box-shadow: 0 4px 16px rgba(17,24,39,0.05); overflow: hidden; }
    .card-header { background: #1a73e8; color: #fff; padding: 20px; font-size: 22px; font-weight: 600; }
    .card-body { padding: 20px; }

    /* ===== Vehicle Information ===== */
    .vehicle-info { display: flex; gap: 24px; align-items: flex-start; flex-wrap: wrap; }
    .vehicle-photo { width: 240px; min-width: 240px; height: 240px; border-radius: 10px; overflow: hidden; background: #f8fafc; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .vehicle-photo img { width: 100%; height: 100%; object-fit: cover; }
    .vehicle-details { flex: 1; display: flex; flex-direction: column; min-width: 300px; }
    .vehicle-title { font-size: 24px; font-weight: 700; color: #0f172a; margin-bottom: 16px; }
    
    .details-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 20px; width: 100%; }
    .detail-item { background: #fbfdff; padding: 12px; border-radius: 8px; border: 1px solid #eef2ff; }
    .detail-label { color: #6b7280; font-size: 13px; margin-bottom: 6px; }
    .detail-value { font-weight: 600; color: #0f172a; }

    /* ===== Buttons ===== */
    .btn-app { padding: 12px 18px; background: #1a73e8; color: #fff; border-radius: 8px; border: none; cursor: pointer; font-size: 14px; font-weight: 500; transition: all 0.2s; white-space: nowrap; flex: 1; min-width: 140px; text-align: center; }
    .btn-app:hover { background: #1557b0; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(26, 115, 232, 0.3); }
    .actions-group { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 20px; padding-top: 20px; border-top: 1px solid #e5e7eb; width: 100%; }

    /* ===== Package Styles ===== */
    .package-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 12px; }

    /* ===== Form Styles ===== */
    .form-label { font-weight: 500; color: #4b5563; margin-bottom: 6px; display: block; font-size: 14px; }

    /* ===== Responsive ===== */
    @media (max-width: 1200px) {
      .vehicle-info { flex-direction: column; }
      .vehicle-photo { width: 100%; height: 250px; }
      .vehicle-details { min-width: auto; }
    }
    @media (max-width: 900px) {
      .left-panel { display: none; }
      .main-content { left: 0; width: 100%; }
      .vehicle-photo { height: 200px; }
      .details-grid { grid-template-columns: 1fr; }
      .btn-app { min-width: 120px; padding: 10px 14px; font-size: 13px; }
    }
    
    /* ===== Scrolling Content ===== */
    html, body { height: 100%; overflow: auto; }
  </style>
</head>
<body>
  <!-- Left Panel Navigation -->
  <div class="left-panel">
    <div class="logo">myCARe</div>
    <a href="/" class="nav-btn" style="display:block; margin-bottom:12px; text-decoration:none;">Trang chủ</a>
    <a href="/phuongtien" class="nav-btn" style="display:block; margin-bottom:12px; text-decoration:none;">Phương tiện</a>
    <div class="desc">Xem chi tiết thông tin phương tiện và quản lý bảo dưỡng, đăng kiểm.</div>
  </div>

  <!-- Main Content -->
  <div class="main-content">
    <!-- Top Navigation Bar -->
    <div class="top-bar">
      <a href="/phuongtien" class="nav-btn">Về Quản lý</a>
      <a href="/dangxuat" class="nav-btn">Đăng xuất</a>
    </div>

    <!-- Content Area -->
    <div style="display: flex; flex-direction: column; gap: 20px;">
      <!-- Vehicle Information Card -->
      <div class="card">
        <div class="card-header">Thông tin phương tiện</div>
        <div class="card-body">
          <div class="vehicle-info">
            <div class="vehicle-photo">
              <% if (vehicle && vehicle.hinh_anh_xe) { %>
                <img src="<%= vehicle.hinh_anh_xe %>" alt="ảnh xe" />
              <% } else { %>
                <div style="color:#9ca3af;">Không có ảnh</div>
              <% } %>
            </div>
            <div class="vehicle-details">
              <div class="vehicle-title"><%= vehicle.bien_so %></div>
              <div class="details-grid">
                <div class="detail-item">
                  <div class="detail-label">Biển số</div>
                  <div class="detail-value"><%= vehicle.bien_so %></div>
                </div>
                <div class="detail-item">
                  <div class="detail-label">Hãng xe</div>
                  <div class="detail-value"><%= vehicle.hang_xe || '-' %></div>
                </div>
                <div class="detail-item">
                  <div class="detail-label">Dòng xe</div>
                  <div class="detail-value"><%= vehicle.dong_xe || '-' %></div>
                </div>
                <div class="detail-item">
                  <div class="detail-label">Ngày tạo</div>
                  <div class="detail-value"><%= vehicle.ngay_tao ? vehicle.ngay_tao.slice(0,10) : '-' %></div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Action Buttons -->
          <div class="actions-group">
            <button id="editVehicleBtn" class="btn-app"><i class="fas fa-edit"></i> Sửa thông tin</button>
            <button id="statsVehicleBtn" class="btn-app" style="background:#0ea5e9;"><i class="fas fa-chart-pie"></i> Thống kê</button>
            <button id="deleteVehicleBtn" class="btn-app" style="background:#ef4444;"><i class="fas fa-trash-alt"></i> Xóa phương tiện</button>
          </div>
        </div>
      </div>

      <!-- Maintenance Package Card -->
      <div class="card">
        <div class="card-header">Gói bảo dưỡng / Đăng kiểm</div>
        <div class="card-body">
          <div class="package-header">
            <div style="font-size:14px; color:#6b7280;">Quản lý các gói bảo dưỡng và đăng kiểm định kỳ</div>
            <div style="display:flex; gap:8px;">
              <button id="togglePackages" class="btn-app" style="background:#0ea5e9;"><i class="fas fa-eye"></i> Xem tất cả</button>
              <button id="addPackageBtn" class="btn-app"><i class="fas fa-plus"></i> Thêm gói</button>
            </div>
          </div>
          <div id="packagesList"></div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // ===== Configuration =====
    const vehicleId = <%= vehicle.id %>;
    const packagesList = document.getElementById('packagesList');
    const SMALL_LIMIT = 2;

    // ===== Utility Functions =====
    function statusBadge(status) {
      const badges = {
        'con_han': '<span class="badge bg-success">Còn hạn</span>',
        'sap_het_han': '<span class="badge bg-warning text-dark">Sắp hết hạn</span>',
        'het_han': '<span class="badge bg-danger">Hết hạn</span>'
      };
      return badges[status] || badges['het_han'];
    }

    function formatDate(dateStr) {
      return dateStr ? dateStr.slice(0, 10) : '-';
    }

    // ===== API Calls =====
    async function fetchPackages() {
      const res = await fetch('/api/bao_duong/' + vehicleId);
      if (!res.ok) throw new Error('Lỗi khi tải dữ liệu');
      return res.json();
    }

    // ===== Package List Rendering =====
    function renderSmallList(data) {
      const sorted = (data || []).slice().sort((a, b) => (b.id || 0) - (a.id || 0));
      const small = sorted.slice(0, SMALL_LIMIT);
      
      if (!small.length) {
        packagesList.innerHTML = '<div class="text-muted">Chưa có gói chu kỳ nào.</div>';
        return;
      }

      packagesList.innerHTML = small.map(p => `
        <div style="padding:8px 0; border-bottom:1px solid #f1f5f9;">
          <div style="font-weight:600;">${p.loai === 'bao_duong' ? 'Bảo dưỡng' : 'Đăng kiểm'} ${statusBadge(p.trang_thai)}</div>
          <div class="text-muted">Thực hiện: ${formatDate(p.ngay_thuc_hien)} · Chu kỳ: ${p.chu_ky_thang} tháng · Hết hạn: ${formatDate(p.ngay_het_han)}</div>
          ${p.ghi_chu ? `<div style="margin-top:6px; font-size:13px;">Ghi chú: ${p.ghi_chu}</div>` : ''}
          <div style="margin-top:8px; display:flex; gap:8px;">
            <button class="btn btn-sm btn-outline-secondary" onclick="editPackage(${p.id})">Sửa</button>
            <button class="btn btn-sm btn-outline-danger" onclick="deletePackage(${p.id})">Xóa</button>
          </div>
        </div>
      `).join('');
    }

    async function showAllModal() {
      try {
        const data = await fetchPackages();
        const rows = (data || []).slice().sort((a, b) => (b.id || 0) - (a.id || 0)).map(p => `
          <div style="padding:8px 0; border-bottom:1px solid #f1f5f9;">
            <div style="font-weight:600;">${p.loai === 'bao_duong' ? 'Bảo dưỡng' : 'Đăng kiểm'} ${statusBadge(p.trang_thai)}</div>
            <div class="text-muted">Thực hiện: ${formatDate(p.ngay_thuc_hien)} · Chu kỳ: ${p.chu_ky_thang} tháng · Hết hạn: ${formatDate(p.ngay_het_han)}</div>
            ${p.ghi_chu ? `<div style="margin-top:6px;">Ghi chú: ${p.ghi_chu}</div>` : ''}
            <div style="margin-top:8px; display:flex; gap:8px;">
              <button class="btn btn-sm btn-outline-secondary" onclick="editPackage(${p.id})">Sửa</button>
              <button class="btn btn-sm btn-outline-danger" onclick="deletePackage(${p.id})">Xóa</button>
            </div>
          </div>
        `).join('');

        const modalId = 'allPackagesModal';
        const existing = document.getElementById(modalId);
        if (existing) existing.remove();

        const html = `
          <div class="modal fade" id="${modalId}" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered" style="max-width: 700px;">
              <div class="modal-content">
                <div class="modal-header">
                  <h5 class="modal-title">Tất cả gói chu kỳ</h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">${rows || '<div class="text-muted">Chưa có gói chu kỳ nào.</div>'}</div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                </div>
              </div>
            </div>
          </div>`;
        
        document.body.insertAdjacentHTML('beforeend', html);
        new bootstrap.Modal(document.getElementById(modalId)).show();
      } catch (err) {
        console.error(err);
        alert('Không thể tải danh sách đầy đủ');
      }
    }

    // ===== Package Management =====
    async function editPackage(id) {
      try {
        const data = await fetchPackages();
        const p = (data || []).find(x => x.id === id);
        if (!p) { alert('Không tìm thấy gói'); return; }

        const [y, m, d] = p.ngay_thuc_hien ? p.ngay_thuc_hien.split('-') : ['', '', ''];
        
        const html = `
          <div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
              <div class="modal-content">
                <div class="modal-header">
                  <h5 class="modal-title">Sửa gói chu kỳ</h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                  <form id="editForm">
                    <div class="mb-3">
                      <label class="form-label">Loại</label>
                      <select class="form-select" name="loai">
                        <option value="bao_duong" ${p.loai === 'bao_duong' ? 'selected' : ''}>Bảo dưỡng</option>
                        <option value="dang_kiem" ${p.loai === 'dang_kiem' ? 'selected' : ''}>Đăng kiểm</option>
                      </select>
                    </div>
                    <div class="mb-3">
                      <label class="form-label">Ngày thực hiện</label>
                      <div class="d-flex gap-2">
                        <select class="form-select" name="day" style="width:30%">${[...Array(31)].map((_, i) => `<option ${String(i+1) === String(d) ? 'selected' : ''}>${i+1}</option>`).join('')}</select>
                        <select class="form-select" name="month" style="width:30%">${[...Array(12)].map((_, i) => `<option ${String(i+1) === String(m) ? 'selected' : ''}>${i+1}</option>`).join('')}</select>
                        <input class="form-control" name="year" value="${y}" />
                      </div>
                    </div>
                    <div class="mb-3">
                      <label class="form-label">Chu kỳ (tháng)</label>
                      <select class="form-select" name="chu_ky">${[...Array(36)].map((_, i) => `<option ${String(i+1) === String(p.chu_ky_thang) ? 'selected' : ''}>${i+1}</option>`).join('')}</select>
                    </div>
                    <div class="mb-3">
                      <label class="form-label">Ghi chú</label>
                      <textarea class="form-control" name="notes" rows="2">${p.ghi_chu || ''}</textarea>
                    </div>
                  </form>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                  <button id="saveBtn" type="button" class="btn btn-primary">Lưu</button>
                </div>
              </div>
            </div>
          </div>`;
        
        document.body.insertAdjacentHTML('beforeend', html);
        const modal = new bootstrap.Modal(document.getElementById('editModal'));
        modal.show();

        document.getElementById('saveBtn').onclick = async () => {
          const form = document.getElementById('editForm');
          const day = String(form.day.value).padStart(2, '0');
          const month = String(form.month.value).padStart(2, '0');
          const year = form.year.value;
          
          try {
            const res = await fetch('/api/bao_duong/' + id, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                loai: form.loai.value,
                ngay_thuc_hien: `${year}-${month}-${day}`,
                chu_ky_thang: form.chu_ky.value,
                ghi_chu: form.notes.value
              })
            });
            if (!res.ok) throw new Error('Lỗi');
            const all = await fetchPackages();
            renderSmallList(all);
            modal.hide();
          } catch (err) {
            alert('Lỗi khi cập nhật: ' + err.message);
          }
        };
      } catch (err) {
        console.error(err);
        alert('Không thể sửa gói');
      }
    }

    async function deletePackage(id) {
      if (!confirm('Xóa gói này?')) return;
      try {
        const res = await fetch('/api/bao_duong/' + id, { method: 'DELETE' });
        if (!res.ok) throw new Error('Lỗi');
        const all = await fetchPackages();
        renderSmallList(all);
      } catch (err) {
        alert('Lỗi khi xóa: ' + err.message);
      }
    }

    // ===== Vehicle Management =====
    document.getElementById('statsVehicleBtn').onclick = () => {
      window.location.href = '/thongkechiphi?id_xe=<%= vehicle.id %>';
    };

    document.getElementById('editVehicleBtn').onclick = () => {
      const html = `
        <div class="modal fade" id="editVehicleModal" tabindex="-1">
          <div class="modal-dialog">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Sửa thông tin phương tiện</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
              </div>
              <div class="modal-body">
                <form id="vehicleForm">
                  <div class="mb-3">
                    <label class="form-label">Biển số</label>
                    <input class="form-control" name="bien_so" value="<%= vehicle.bien_so %>" required />
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Hãng</label>
                    <input class="form-control" name="hang_xe" value="<%= vehicle.hang_xe || '' %>" />
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Dòng</label>
                    <input class="form-control" name="dong_xe" value="<%= vehicle.dong_xe || '' %>" />
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Ảnh</label>
                    <input class="form-control" type="file" name="hinh_anh_xe" accept="image/*" />
                  </div>
                </form>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button id="saveVehicleBtn" type="button" class="btn btn-primary">Lưu</button>
              </div>
            </div>
          </div>
        </div>`;
      
      document.body.insertAdjacentHTML('beforeend', html);
      const modal = new bootstrap.Modal(document.getElementById('editVehicleModal'));
      modal.show();

      document.getElementById('saveVehicleBtn').onclick = async () => {
        try {
          const res = await fetch('/phuongtien/sua/<%= vehicle.id %>', {
            method: 'POST',
            body: new FormData(document.getElementById('vehicleForm'))
          });
          if (!res.ok) throw new Error('Lỗi');
          window.location.href = '/phuongtien';
        } catch (err) {
          alert('Lỗi: ' + err.message);
        }
      };
    };

    document.getElementById('deleteVehicleBtn').onclick = async () => {
      if (!confirm('Xóa phương tiện này?')) return;
      try {
        const res = await fetch('/phuongtien/xoa/<%= vehicle.id %>', { method: 'POST' });
        if (!res.ok) throw new Error('Lỗi');
        window.location.href = '/phuongtien';
      } catch (err) {
        alert('Lỗi: ' + err.message);
      }
    };

    // ===== Add Package Modal =====
    document.getElementById('addPackageBtn').onclick = () => {
      const days = [...Array(31)].map((_, i) => `<option value="${i+1}">${i+1}</option>`).join('');
      const months = [...Array(12)].map((_, i) => `<option value="${i+1}">${i+1}</option>`).join('');
      const years = [...Array(21)].map((_, i) => `<option value="${new Date().getFullYear() - 5 + i}">${new Date().getFullYear() - 5 + i}</option>`).join('');

      const html = `
        <div class="modal fade" id="addModal" tabindex="-1">
          <div class="modal-dialog">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Thêm gói chu kỳ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
              </div>
              <div class="modal-body">
                <form id="addForm">
                  <div class="mb-3">
                    <label class="form-label">Loại</label>
                    <select class="form-select" name="loai" required>
                      <option value="bao_duong">Bảo dưỡng</option>
                      <option value="dang_kiem">Đăng kiểm</option>
                    </select>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Ngày thực hiện</label>
                    <div class="d-flex gap-2">
                      <select class="form-select" name="day">${days}</select>
                      <select class="form-select" name="month">${months}</select>
                      <select class="form-select" name="year">${years}</select>
                    </div>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Chu kỳ (tháng)</label>
                    <select class="form-select" name="chu_ky" required>${[...Array(12)].map((_, i) => `<option value="${i+1}">${i+1} tháng</option>`).join('')}</select>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Ghi chú</label>
                    <textarea class="form-control" name="notes" rows="2"></textarea>
                  </div>
                </form>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button id="addSaveBtn" type="button" class="btn btn-primary">Lưu</button>
              </div>
            </div>
          </div>
        </div>`;
      
      document.body.insertAdjacentHTML('beforeend', html);
      const modal = new bootstrap.Modal(document.getElementById('addModal'));
      modal.show();

      document.getElementById('addSaveBtn').onclick = async () => {
        const form = document.getElementById('addForm');
        const day = String(form.day.value).padStart(2, '0');
        const month = String(form.month.value).padStart(2, '0');
        const year = form.year.value;

        try {
          const res = await fetch('/api/bao_duong', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              id_xe: vehicleId,
              loai: form.loai.value,
              ngay_thuc_hien: `${year}-${month}-${day}`,
              chu_ky_thang: form.chu_ky.value,
              ghi_chu: form.notes.value
            })
          });
          if (!res.ok) throw new Error('Lỗi');
          const all = await fetchPackages();
          renderSmallList(all);
          modal.hide();
        } catch (err) {
          alert('Lỗi: ' + err.message);
        }
      };
    };

    // ===== Initialize =====
    (async () => {
      try {
        const data = await fetchPackages();
        renderSmallList(data);
      } catch (err) {
        packagesList.innerHTML = '<div class="text-danger">Không thể tải gói chu kỳ</div>';
      }
    })();

    document.getElementById('togglePackages').onclick = showAllModal;
  </script>
</body>
