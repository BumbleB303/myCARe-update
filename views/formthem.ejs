<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Thêm địa điểm <%= loai.toUpperCase() %> - myCARe</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Modak&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
  body { margin: 0; font-family: 'Arial', sans-serif; background: #f0f2f5; overflow: auto; }
  .content, .main-content, .content-area { overflow-y: auto; }
    .left-panel {
      position: fixed; top: 0; left: 0; width: 320px; height: 100vh; background: #fff; z-index: 1002;
      border-right: 1px solid #e6e9ee; padding: 24px; box-shadow: 2px 0 8px rgba(15,23,42,0.04);
    }
    .left-panel .logo {
      font-family: 'Modak', cursive;
      font-size: 36px;
      background: linear-gradient(90deg, #1a73e8, #03f007);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: 3px;
    }
    .left-panel .desc { color: #6b7280; font-size: 15px; line-height: 1.5; margin: 16px 0; }
    
    .main-content {
      position: absolute; top: 0; left: 320px; width: calc(100% - 320px); height: 100vh; padding: 24px;
      display: flex; flex-direction: column;
    }
    .top-bar {
      display: flex; justify-content: flex-end; padding: 8px 0; margin-bottom: 20px;
    }

      .user-info {
      margin-top: 300px;
      padding: 16px;
      background: #f8fafc;
      border-radius: 8px;
      border: 1px solid #e5e7eb;
    }
    .user-info .name {
      font-weight: 600;
      color: #1f2937;
      margin-bottom: 4px;
    }
    .user-info .role {
      color: #6b7280;
      font-size: 14px;
    }

    .nav-btn {
      background: #1a73e8; border: none; padding: 10px 20px; margin: 0 8px; color: #fff;
      font-size: 15px; border-radius: 6px; cursor: pointer; transition: all 0.2s;
    }
    .nav-btn:hover { background: #1557b0; transform: translateY(-1px); }
    .btn-danger { background: #dc2626; }
    .btn-danger:hover { background: #b91c1c; }

    .form-container { 
      background: #fff; max-width: 800px; margin: 0 auto; width: 100%;
      padding: 32px; border-radius: 12px; box-shadow: 0 4px 16px rgba(17,24,39,0.05);
    }
    .form-header { font-size: 24px; color: #1f2937; font-weight: 600; margin-bottom: 24px; }
    .form-group { margin-bottom: 20px; }
    label { 
      display: block; font-size: 15px; color: #4b5563; font-weight: 500; 
      margin-bottom: 8px;
    }
    input:not([type="file"]) { 
      width: 100%; padding: 10px 12px; font-size: 15px; border: 1px solid #e5e7eb;
      border-radius: 8px; transition: all 0.2s;
    }
    input:not([type="file"]):focus {
      border-color: #1a73e8; box-shadow: 0 0 0 3px rgba(26,115,232,0.12);
      outline: none;
    }
    input[type="file"] { 
      width: 100%; padding: 8px 0;
      border: 1px dashed #e5e7eb; border-radius: 8px;
      background: #f9fafb; cursor: pointer;
    }
    .btn-app {
      background: #1a73e8; color: #fff; padding: 12px 24px; border: none;
      border-radius: 8px; font-size: 16px; font-weight: 500; cursor: pointer;
      transition: all 0.2s;
    }
    .btn-app:hover { background: #1557b0; transform: translateY(-1px); }
    .btn-secondary {
      background: #6b7280; color: #fff; padding: 12px 24px; border: none;
      border-radius: 8px; font-size: 16px; font-weight: 500; cursor: pointer;
      transition: all 0.2s; margin-top: 16px;
    }
    .btn-secondary:hover { background: #4b5563; transform: translateY(-1px); }

    @media (max-width: 900px) {
      .left-panel { display: none; }
      .main-content { left: 0; width: 100%; }
    }
  </style>
</head>
<body>
  <div class="left-panel">
    <div class="logo">myCARe</div>
    <a href="/" class="nav-btn" style="display:block; margin-bottom:12px; text-decoration:none; text-align:left;">Trang chủ</a>
    <div class="desc">
      Thêm địa điểm mới vào hệ thống quản lý dịch vụ xe điện tại Hà Nội.
    </div>
    <div class="desc" style="margin-top:32px;">
      Các thông tin cần thiết:
      <ul style="margin-top:8px; color:#374151;">
        <li>• Tên và địa chỉ chi tiết</li>
        <li>• Thông tin liên hệ</li>
        <li>• Giờ hoạt động</li>
        <li>• Hình ảnh địa điểm</li>
        <li>• Tọa độ chính xác</li>
      </ul>
    </div>

    <div class="user-info">
      <% if (!user) { %>
        <div style="text-align:center;">
          <div style="margin-bottom:8px; color:#1f2937; font-weight:600;">Khách</div>
          <a class="nav-btn" href="/dangnhap" style="display:inline-block;">Đăng nhập</a>
        </div>
      <% } else { %>
        <div class="name"><%= user.tentaikhoan %></div>
        <div class="role"><%= user.role === 'quantrivien' ? 'Quản trị viên' : 'Người dùng' %></div>
      <% } %>
    </div>

  </div>

  <div class="main-content">
    <div class="top-bar">
      <a href="/quanly/diadiem" class="nav-btn">Quay lại quản lý</a>
      <a href="/dangxuat" class="nav-btn btn-danger">Đăng xuất</a>
    </div>

    <div class="form-container">
      <div class="form-header">Thêm địa điểm <%= loai.toUpperCase() %></div>
      <form action="/themdiadiem/<%= loai %>" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="type" value="<%= loai %>">
        <div class="form-group">
          <label for="name">Tên địa điểm</label>
          <input type="text" id="name" name="name" required 
                 placeholder="Nhập tên địa điểm">
        </div>
        <div class="form-group">
          <label for="diachi">Địa chỉ</label>
          <input type="text" id="diachi" name="diachi" required
                 placeholder="Nhập địa chỉ chi tiết">
        </div>
        <div class="form-group">
          <label for="lienhe">Thông tin liên hệ</label>
          <input type="text" id="lienhe" name="lienhe"
                 placeholder="Số điện thoại hoặc email liên hệ">
        </div>
        <div class="form-group">
          <label for="giomocua">Giờ mở cửa</label>
          <input type="time" id="giomocua" name="giomocua">
        </div>
        <div class="form-group">
          <label for="giodongcua">Giờ đóng cửa</label>
          <input type="time" id="giodongcua" name="giodongcua">
        </div>
        <% if (loai === 'tramsac') { %>
          <div class="form-group">
            <label for="nhacungcap">Nhà cung cấp dịch vụ</label>
            <input type="text" id="nhacungcap" name="nhacungcap"
                   placeholder="Tên công ty/đơn vị cung cấp">
          </div>
        <% } %>
        <div class="form-group">
          <label for="hinhanh">Hình ảnh địa điểm</label>
          <input type="file" id="hinhanh" name="hinhanh"
                 accept="image/*">
        </div>
        <div class="form-group">
          <label for="lat">Vĩ độ (Latitude)</label>
          <input type="number" step="0.000001" id="lat" name="lat" required
                 placeholder="Nhập vĩ độ (ví dụ: 21.028511)">
        </div>
        <div class="form-group">
          <label for="lon">Kinh độ (Longitude)</label>
          <input type="number" step="0.000001" id="lon" name="lon" required
                 placeholder="Nhập kinh độ (ví dụ: 105.804817)">
        </div>
        <button type="submit" class="btn-app">Thêm địa điểm</button>
      </form>
      <a href="/themdiadiem" class="btn-secondary d-inline-block">Quay lại</a>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>