<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="utf-8"/>
<title>Thêm <%= loai %></title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-4">
  <h2>Thêm: <%= loai %></h2>

  <form id="addForm" action="/themdiadiem/<%= loai %>" method="POST">
    <table class="table">
      <tbody>
        <% fields.forEach(f => { %>
          <tr>
            <td><label><%= f.column_name %></label></td>
            <td>
              <% if (f.data_type.includes('double')) { %>
                <input name="<%= f.column_name %>" class="form-control" type="number" step="any" />
              <% } else { %>
                <input name="<%= f.column_name %>" class="form-control" type="text" />
              <% } %>
            </td>
          </tr>
        <% }) %>

        <tr>
          <td><label>Kinh độ (lon)</label></td>
          <td><input required name="lon" id="lon" class="form-control" type="text" /></td>
        </tr>
        <tr>
          <td><label>Vĩ độ (lat)</label></td>
          <td><input required name="lat" id="lat" class="form-control" type="text" /></td>
        </tr>
      </tbody>
    </table>

    <button type="submit" class="btn btn-success">Lưu</button>
    <a href="/themdiadiem" class="btn btn-secondary">Hủy</a>
  </form>

  <script>
    document.getElementById('addForm').addEventListener('submit', function(e){
      const lat = document.getElementById('lat').value.trim();
      const lon = document.getElementById('lon').value.trim();
      if (isNaN(Number(lat)) || isNaN(Number(lon))) {
        alert('Lat/Lon phải là số');
        e.preventDefault();
      }
    });
  </script>
</body>
</html>
