<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>myCARe - Ghi chú cá nhân</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Modak&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
  body { margin: 0; font-family: 'Arial', sans-serif; background: #f0f2f5; overflow: auto; }
  .content, .main-content, .content-area { overflow-y: auto; }
    
    .left-panel {
      position: fixed; top: 0; left: 0; width: 320px; height: 100vh; background: #fff; z-index: 1002;
      border-right: 1px solid #e6e9ee; padding: 24px; box-shadow: 2px 0 8px rgba(15,23,42,0.04);
      overflow-y: auto;
    }
    .left-panel .logo {
      font-family: 'Modak', cursive;
      font-size: 36px;
      background: linear-gradient(90deg, #1a73e8, #03f007);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: 3px;
    }
    .left-panel .desc { color: #6b7280; font-size: 15px; line-height: 1.5; margin: 16px 0; }
    
    .main-content {
      position: absolute; top: 0; left: 320px; width: calc(100% - 320px); height: 100vh; padding: 24px;
      display: flex; flex-direction: column;
    }
    .top-bar {
      display: flex; justify-content: flex-end; padding: 8px 0; margin-bottom: 20px;
    }
    .nav-btn {
      background: #1a73e8; border: none; padding: 10px 20px; margin: 0 8px; color: #fff;
      font-size: 15px; border-radius: 6px; cursor: pointer; transition: all 0.2s;
      text-decoration: none;
    }
    .nav-btn:hover { background: #1557b0; transform: translateY(-1px); color: #fff; }
    .btn-danger { background: #dc2626; }
    .btn-danger:hover { background: #b91c1c; }
    .btn-primary { background: #10b981; }
    .btn-primary:hover { background: #059669; }

    .content-area {
      flex: 1; overflow-y: auto; padding: 20px;
    }
    .info-card {
      width: 100%; max-width: 800px; background: #fff; border-radius: 12px;
      box-shadow: 0 4px 16px rgba(17,24,39,0.05); overflow: hidden;
      margin: 0 auto;
    }
    .info-header {
      background: #1a73e8;
      color: #fff; padding: 24px; text-align: center;
      font-size: 24px; font-weight: 600;
    }
    .info-body {
      padding: 24px;
    }
    .notes-list {
      list-style: none; padding: 0; margin: 0;
    }
    .note-item {
      background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px;
      padding: 16px; margin-bottom: 16px; transition: all 0.2s;
    }
    .note-item:hover {
      box-shadow: 0 4px 12px rgba(17,24,39,0.08);
      border-color: #d1d5db;
    }
    .note-title {
      font-size: 16px; font-weight: 600; color: #111827; margin-bottom: 8px;
      word-wrap: break-word;
    }
    .note-content {
      font-size: 14px; color: #4b5563; line-height: 1.6; margin-bottom: 12px;
      word-wrap: break-word; white-space: pre-wrap;
    }
    .note-date {
      font-size: 13px; color: #9ca3af;
    }
    .note-actions {
      margin-top: 12px; display: flex; gap: 8px;
    }
    .btn-sm {
      padding: 6px 12px; font-size: 13px; border: none; border-radius: 6px;
      cursor: pointer; transition: all 0.2s;
    }
    .btn-edit {
      background: #3b82f6; color: #fff;
    }
    .btn-edit:hover {
      background: #2563eb; transform: translateY(-1px);
    }
    .btn-delete {
      background: #ef4444; color: #fff;
    }
    .btn-delete:hover {
      background: #dc2626; transform: translateY(-1px);
    }
    .empty-state {
      text-align: center; padding: 48px 24px; color: #6b7280;
    }
    .empty-icon {
      font-size: 48px; color: #d1d5db; margin-bottom: 16px;
    }

    .btn-app {
      width: 100%; max-width: 300px; padding: 12px; font-size: 16px;
      border-radius: 8px; margin: 16px 0; font-weight: 500;
      background: #1a73e8; color: #fff; border: none;
      transition: all 0.2s; cursor: pointer;
    }
    .btn-app:hover { background: #1557b0; transform: translateY(-1px); }

    /* Modal styles */
    .modal {
      display: none; position: fixed; top: 0; left: 0;
      width: 100%; height: 100%; background: rgba(0,0,0,0.5);
      justify-content: center; align-items: center;
      backdrop-filter: blur(4px); z-index: 1010; overflow-y: auto;
    }
    .modal-content {
      background: #fff; padding: 32px; border-radius: 12px;
      width: 90%; max-width: 600px; position: relative;
      box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
      margin: 20px auto;
    }
    .modal-title {
      font-size: 20px; font-weight: 600; color: #111827;
      margin-bottom: 24px; text-align: center;
    }
    .close {
      position: absolute; top: 16px; right: 16px;
      font-size: 24px; cursor: pointer; color: #6b7280;
      border: none; background: none; padding: 4px;
      transition: all 0.2s;
    }
    .close:hover { color: #111827; transform: rotate(90deg); }
    
    .form-group {
      margin-bottom: 20px;
    }
    .form-label {
      font-weight: 500; color: #4b5563; margin-bottom: 8px;
      display: block; font-size: 15px;
    }
    .form-input {
      width: 100%; padding: 10px 12px; font-size: 15px;
      border: 1px solid #e5e7eb; border-radius: 8px;
      transition: all 0.2s;
      font-family: 'Arial', sans-serif;
    }
    .form-input:focus {
      border-color: #1a73e8; box-shadow: 0 0 0 3px rgba(26,115,232,0.12);
      outline: none;
    }
    textarea.form-input {
      resize: vertical; min-height: 120px; font-family: 'Arial', sans-serif;
    }

    @media (max-width: 900px) {
      .left-panel { display: none; }
      .main-content { left: 0; width: 100%; }
      .info-card { margin: 0 16px; }
      .modal-content { margin: 16px; }
    }
  </style>
</head>
<body>
  <div class="left-panel">
    <div class="logo">myCARe</div>
    <a href="/" class="nav-btn" style="display:block; margin-bottom:12px; text-decoration:none; text-align:left;">Trang chủ</a>
    <a href="/phuongtien" class="nav-btn" style="display:block; margin-bottom:12px; text-decoration:none; text-align:left;">Phương tiện</a>
    <div class="desc">
      Quản lý các ghi chú cá nhân trên ứng dụng myCARe.
    </div>
    <div class="desc" style="margin-top:32px;">
      Các thao tác:
      <ul style="margin-top:8px; color:#374151;">
        <li>• Tạo ghi chú mới</li>
        <li>• Chỉnh sửa ghi chú</li>
        <li>• Xóa ghi chú</li>
        <li>• Xem danh sách ghi chú</li>
      </ul>
    </div>
  </div>

  <div class="main-content">
    <div class="top-bar">
      <div class="d-flex">
        <button class="nav-btn btn-primary" onclick="openAddNoteModal()" style="background: #10b981;">
          <i class="fas fa-plus"></i> Thêm ghi chú
        </button>
        <a href="/thongtinnguoidung" class="nav-btn">Quay lại</a>
        <a href="/dangxuat" class="nav-btn btn-danger">Đăng xuất</a>
      </div>
    </div>

    <div class="content-area">
      <div class="info-card">
        <div class="info-header">
          <i class="fas fa-sticky-note"></i> Ghi chú cá nhân
        </div>
        <div class="info-body">
          <ul class="notes-list" id="notesList">
            <div class="empty-state">
              <div class="empty-icon">
                <i class="fas fa-inbox"></i>
              </div>
              <p>Hiện chưa có ghi chú nào</p>
            </div>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal Thêm/Chỉnh sửa ghi chú -->
  <div id="noteModal" class="modal">
    <div class="modal-content">
      <span class="close" onclick="closeNoteModal()">&times;</span>
      <div class="modal-title" id="modalTitle">Thêm ghi chú mới</div>
      <form id="noteForm" onsubmit="saveNote(event)">
        <div class="form-group">
          <label class="form-label" for="noteTitle">Tiêu đề</label>
          <input type="text" id="noteTitle" class="form-input" placeholder="Nhập tiêu đề ghi chú" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="noteContent">Nội dung</label>
          <textarea id="noteContent" class="form-input" placeholder="Nhập nội dung ghi chú" required></textarea>
        </div>
        <div class="text-center">
          <button type="submit" class="btn-app" style="background: #10b981;">
            <i class="fas fa-save"></i> Lưu ghi chú
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    let notes = [];
    let editingNoteId = null;

    // Load notes on page load
    document.addEventListener('DOMContentLoaded', function() {
      loadNotes();
    });

    function loadNotes() {
      fetch('/api/ghichucanhan')
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            notes = data.data || [];
            renderNotes();
          } else {
            console.error('Lỗi khi tải ghi chú:', data.message);
          }
        })
        .catch(error => {
          console.error('Lỗi:', error);
          alert('Có lỗi xảy ra khi tải ghi chú');
        });
    }

    function renderNotes() {
      const notesList = document.getElementById('notesList');
      
      if (notes.length === 0) {
        notesList.innerHTML = `
          <div class="empty-state">
            <div class="empty-icon">
              <i class="fas fa-inbox"></i>
            </div>
            <p>Hiện chưa có ghi chú nào</p>
          </div>
        `;
        return;
      }

      notesList.innerHTML = notes.map(note => {
        const date = new Date(note.ngay_tao);
        const formattedDate = date.toLocaleDateString('vi-VN', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        });

        return `
          <li class="note-item">
            <div class="note-title">${escapeHtml(note.tieu_de)}</div>
            <div class="note-content">${escapeHtml(note.noi_dung)}</div>
            <div class="note-date">
              <i class="fas fa-calendar"></i> ${formattedDate}
            </div>
            <div class="note-actions">
              <button class="btn-sm btn-edit" onclick="editNote(${note.id})">
                <i class="fas fa-edit"></i> Chỉnh sửa
              </button>
              <button class="btn-sm btn-delete" onclick="deleteNote(${note.id})">
                <i class="fas fa-trash"></i> Xóa
              </button>
            </div>
          </li>
        `;
      }).join('');
    }

    function openAddNoteModal() {
      editingNoteId = null;
      document.getElementById('modalTitle').textContent = 'Thêm ghi chú mới';
      document.getElementById('noteTitle').value = '';
      document.getElementById('noteContent').value = '';
      document.getElementById('noteModal').style.display = 'flex';
    }

    function closeNoteModal() {
      document.getElementById('noteModal').style.display = 'none';
      document.getElementById('noteForm').reset();
      editingNoteId = null;
    }

    function editNote(noteId) {
      const note = notes.find(n => n.id === noteId);
      if (!note) return;

      editingNoteId = noteId;
      document.getElementById('modalTitle').textContent = 'Chỉnh sửa ghi chú';
      document.getElementById('noteTitle').value = note.tieu_de;
      document.getElementById('noteContent').value = note.noi_dung;
      document.getElementById('noteModal').style.display = 'flex';
    }

    function saveNote(event) {
      event.preventDefault();
      
      const title = document.getElementById('noteTitle').value.trim();
      const content = document.getElementById('noteContent').value.trim();

      if (!title || !content) {
        alert('Vui lòng điền đầy đủ thông tin');
        return;
      }

      const method = editingNoteId ? 'PUT' : 'POST';
      const url = editingNoteId ? `/api/ghichucanhan/${editingNoteId}` : '/api/ghichucanhan';

      fetch(url, {
        method: method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tieu_de: title, noi_dung: content })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          alert(editingNoteId ? 'Cập nhật ghi chú thành công' : 'Tạo ghi chú thành công');
          closeNoteModal();
          loadNotes();
        } else {
          alert('Lỗi: ' + (data.message || 'Không thể lưu ghi chú'));
        }
      })
      .catch(error => {
        console.error('Lỗi:', error);
        alert('Có lỗi xảy ra khi lưu ghi chú');
      });
    }

    function deleteNote(noteId) {
      if (!confirm('Bạn chắc chắn muốn xóa ghi chú này?')) return;

      fetch(`/api/ghichucanhan/${noteId}`, {
        method: 'DELETE'
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          alert('Xóa ghi chú thành công');
          loadNotes();
        } else {
          alert('Lỗi: ' + (data.message || 'Không thể xóa ghi chú'));
        }
      })
      .catch(error => {
        console.error('Lỗi:', error);
        alert('Có lỗi xảy ra khi xóa ghi chú');
      });
    }

    function escapeHtml(text) {
      const map = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;'
      };
      return text.replace(/[&<>"']/g, m => map[m]);
    }

    // Đóng modal khi nhấn ngoài vùng
    window.onclick = function(event) {
      const modal = document.getElementById('noteModal');
      if (event.target == modal) {
        closeNoteModal();
      }
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
