<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Quản lý tài khoản - myCARe</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Modak&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
  body { margin: 0; font-family: 'Arial', sans-serif; background: #f0f2f5; overflow: auto; }
  .content, .main-content, .content-area { overflow-y: auto; }
    
    .left-panel {
      position: fixed; top: 0; left: 0; width: 320px; height: 100vh; background: #fff; z-index: 1002;
      border-right: 1px solid #e6e9ee; padding: 24px; box-shadow: 2px 0 8px rgba(15,23,42,0.04);
    }
    .left-panel .logo {
      font-family: 'Modak', cursive;
      font-size: 36px;
      background: linear-gradient(90deg, #1a73e8, #03f007);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      letter-spacing: 3px;
    }
    .left-panel .desc { color: #6b7280; font-size: 15px; line-height: 1.5; margin: 16px 0; }
    
    .main-content {
      position: absolute; top: 0; left: 320px; width: calc(100% - 320px); height: 100vh; padding: 24px;
      display: flex; flex-direction: column;
    }

    .user-info {
      margin-top: 300px;
      padding: 16px;
      background: #f8fafc;
      border-radius: 8px;
      border: 1px solid #e5e7eb;
    }
    .user-info .name {
      font-weight: 600;
      color: #1f2937;
      margin-bottom: 4px;
    }
    .user-info .role {
      color: #6b7280;
      font-size: 14px;
    }

    .top-bar {
      display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;
    }
    .nav-btn {
      background: #1a73e8; border: none; padding: 10px 20px; margin: 0 8px; color: #fff;
      font-size: 15px; border-radius: 6px; cursor: pointer; transition: all 0.2s;
      text-decoration: none;
    }
    .nav-btn:hover { background: #1557b0; transform: translateY(-1px); color: #fff; }
    .btn-danger { background: #dc2626; }
    .btn-danger:hover { background: #b91c1c; }

    .user-table { 
      width: 100%; border-collapse: separate; border-spacing: 0; background: #fff;
      border-radius: 12px; overflow: hidden; box-shadow: 0 4px 16px rgba(17,24,39,0.05);
    }
    th, td { 
      padding: 16px; text-align: center; border-bottom: 1px solid #e5e7eb;
      font-size: 14px; color: #374151;
    }
    th { 
      background: #1a73e8; color: #fff; font-weight: 600; text-transform: uppercase;
      font-size: 13px; letter-spacing: 0.5px;
    }
    tr:nth-child(even) { background: #f9fafb; }
    tr:hover { background: #f3f4f6; }
    
    .action-btn {
      padding: 8px 16px; border: none; border-radius: 6px; cursor: pointer;
      font-size: 14px; transition: all 0.2s; display: inline-flex;
      align-items: center; gap: 6px; background: #ef4444; color: #fff;
    }
    .action-btn:hover { 
      background: #dc2626; transform: translateY(-1px);
    }
    
    .no-data { 
      text-align: center; color: #6b7280; padding: 32px;
      font-size: 16px; background: #fff; border-radius: 12px;
      box-shadow: 0 4px 16px rgba(17,24,39,0.05);
    }

    @media (max-width: 900px) {
      .left-panel { display: none; }
      .main-content { left: 0; width: 100%; }
    }
  </style>
</head>
<body>
  <div class="left-panel">
    <div class="logo">myCARe</div>
    <a href="/" class="nav-btn" style="display:block; margin-bottom:12px; text-decoration:none; text-align:left;">Trang chủ</a>
    <div class="desc">
      Quản lý thông tin tài khoản trên hệ thống.
    </div>
    <div class="desc" style="margin-top:32px;">
      Các chức năng:
      <ul style="margin-top:8px; color:#374151;">
        <li>• Xem danh sách tài khoản</li>
        <li>• Quản lý tài khoản</li>
        <li>• Xóa tài khoản</li>
      </ul>
    </div>

    <div class="user-info">
      <% if (!user) { %>
        <div style="text-align:center;">
          <div style="margin-bottom:8px; color:#1f2937; font-weight:600;">Khách</div>
          <a class="nav-btn" href="/dangnhap" style="display:inline-block;">Đăng nhập</a>
        </div>
      <% } else { %>
        <div class="name"><%= user.tentaikhoan %></div>
        <div class="role"><%= user.role === 'quantrivien' ? 'Quản trị viên' : 'Người dùng' %></div>
      <% } %>
    </div>

  </div>

  <div class="main-content">
    <div class="top-bar">
      <div class="logo" style="color: #1f2937; font-size: 24px; font-weight: 600;">
        Quản lý tài khoản
      </div>
      <div class="d-flex">
        <a href="/quanly" class="nav-btn">Quay lại</a>
        <a href="/dangxuat" class="nav-btn btn-danger">Đăng xuất</a>
      </div>
    </div>

    <div id="content">
      <% if (users.length === 0) { %>
        <div class="no-data">
          <i class="bi bi-people" style="font-size: 24px; margin-bottom: 12px; display: block;"></i>
          Chưa có người dùng nào trong hệ thống
        </div>
      <% } else { %>
        <table class="user-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Tên tài khoản</th>
              <th>Email</th>
              <th>Số điện thoại</th>
              <th>Loại tài khoản</th>
              <th>Thao tác</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(user => { %>
              <tr>
                <td><%= user.id %></td>
                <td>
                  <%= user.tentaikhoan %>
                  <% if (user.id === currentUser.id) { %>
                    <span class="badge bg-info" style="font-size: 11px; padding: 4px 8px; margin-left: 4px;">Bạn</span>
                  <% } %>
                </td>
                <td><%= user.email || 'Chưa cập nhật' %></td>
                <td><%= user.sdt %></td>
                <td>
                  <% if (user.role === 'quantrivien') { %>
                    <span class="badge bg-primary" style="font-size: 12px; padding: 6px 10px;">Quản trị viên</span>
                  <% } else { %>
                    <span class="badge bg-secondary" style="font-size: 12px; padding: 6px 10px;">Người dùng</span>
                  <% } %>
                </td>
                <td>
                  <div class="d-flex gap-2 justify-content-center">
                    <button class="action-btn" style="background: #1a73e8;" 
                            onclick="openEditModal('<%= user.id %>', '<%= user.tentaikhoan %>', '<%= user.email %>', '<%= user.sdt %>')"
                            title="Sửa thông tin">
                      <i class="bi bi-pencil-square"></i>
                      <span>Sửa</span>
                    </button>

                    <button class="action-btn" style="background: #f59e0b;"
                            onclick="location.href='/quanly/ghichu/<%= user.id %>'"
                            title="Xem ghi chú">
                      <i class="bi bi-sticky"></i>
                      <span>Ghi chú</span>
                    </button>

                    <button class="action-btn" style="background: #06b6d4;"
                            onclick="location.href='/quanlyphuongtien?uid=<%= user.id %>'"
                            title="Xem phương tiện">
                      <i class="bi bi-bicycle"></i>
                      <span>Phương tiện</span>
                    </button>

                    <% if (user.role === 'nguoidung') { %>
                      <button class="action-btn" style="background: #15803d;" 
                              onclick="openGrantModal('<%= user.id %>', '<%= user.tentaikhoan %>')"
                              title="Cấp quyền quản trị">
                        <i class="bi bi-shield-check"></i>
                        <span>Cấp quyền</span>
                      </button>
                    <% } %>

                    <% if (user.id !== currentUser.id) { %>
                      <% if (user.role === 'quantrivien') { %>
                        <button class="action-btn" style="background: #dc2626;"
                                onclick="openDeleteAdminModal('<%= user.id %>', '<%= user.tentaikhoan %>')"
                                title="Xóa tài khoản">
                          <i class="bi bi-trash"></i>
                          <span>Xóa</span>
                        </button>
                      <% } else { %>
                        <form action="/quanly/nguoidung/xoa/<%= user.id %>" method="POST" 
                              onsubmit="return confirm('Bạn có chắc muốn xóa tài khoản <%= user.tentaikhoan %>?');" 
                              class="d-inline">
                          <button type="submit" class="action-btn" style="background: #dc2626;"
                                  title="Xóa tài khoản">
                            <i class="bi bi-trash"></i>
                            <span>Xóa</span>
                          </button>
                        </form>
                      <% } %>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

  <!-- Modal cấp quyền -->
  <div id="grantModal" class="modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; 
       background:rgba(0,0,0,0.5); backdrop-filter:blur(4px); z-index:1050;">
    <div class="modal-content" style="background:#fff; width:90%; max-width:450px; margin:100px auto; padding:32px; 
         border-radius:12px; box-shadow:0 20px 25px -5px rgba(0,0,0,0.1); position:relative;">
      <span class="close" onclick="closeGrantModal()" 
            style="position:absolute; right:16px; top:16px; font-size:24px; cursor:pointer; color:#6b7280;">&times;</span>
      
      <div style="text-align:center; margin-bottom:24px;">
        <div style="font-size:24px; font-weight:600; color:#1f2937; margin-bottom:8px;">
          Xác nhận cấp quyền quản trị
        </div>
        <div style="color:#6b7280; font-size:15px;" id="confirmText"></div>
      </div>

      <div style="margin-bottom:20px;">
        <label style="display:block; margin-bottom:8px; font-weight:500; color:#4b5563;">
          Nhập mật khẩu của bạn để xác nhận
        </label>
        <input type="password" id="adminPassword" 
               style="width:100%; padding:10px 12px; border:1px solid #e5e7eb; border-radius:8px; font-size:15px;"
               placeholder="Nhập mật khẩu">
        <div id="passwordError" style="color:#dc2626; font-size:14px; margin-top:6px; display:none;">
          Mật khẩu không đúng
        </div>
      </div>

      <input type="hidden" id="userId">
      <input type="hidden" id="username">

      <div style="text-align:center;">
        <button onclick="confirmGrant()" class="nav-btn" style="width:100%; margin:0;">
          Xác nhận cấp quyền
        </button>
      </div>
    </div>
  </div>

  <script>
    function openGrantModal(userId, username) {
      document.getElementById('grantModal').style.display = 'block';
      document.getElementById('userId').value = userId;
      document.getElementById('username').value = username;
      document.getElementById('confirmText').textContent = 
        `Bạn có chắc muốn cấp quyền quản trị viên cho tài khoản "${username}"?`;
      document.getElementById('adminPassword').value = '';
      document.getElementById('passwordError').style.display = 'none';
    }

    function closeGrantModal() {
      document.getElementById('grantModal').style.display = 'none';
    }

    function confirmGrant() {
      const userId = document.getElementById('userId').value;
      const username = document.getElementById('username').value;
      const password = document.getElementById('adminPassword').value;

      if (!password) {
        alert('Vui lòng nhập mật khẩu để xác nhận');
        return;
      }

      fetch('/quanly/nguoidung/capquyen/' + userId, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ password: password })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          alert('Đã cấp quyền quản trị viên thành công cho tài khoản ' + username);
          location.reload();
        } else {
          document.getElementById('passwordError').style.display = 'block';
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Có lỗi xảy ra khi cấp quyền');
      });
    }

    // Đóng modal khi click ngoài
    window.onclick = function(event) {
      const modal = document.getElementById('grantModal');
      if (event.target == modal) {
        closeGrantModal();
      }
    }
  </script>

  <!-- Modal sửa thông tin -->
  <div id="editModal" class="modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; 
       background:rgba(0,0,0,0.5); backdrop-filter:blur(4px); z-index:1050;">
    <div class="modal-content" style="background:#fff; width:90%; max-width:450px; margin:100px auto; padding:32px; 
         border-radius:12px; box-shadow:0 20px 25px -5px rgba(0,0,0,0.1); position:relative;">
      <span class="close" onclick="closeEditModal()" 
            style="position:absolute; right:16px; top:16px; font-size:24px; cursor:pointer; color:#6b7280;">&times;</span>
      
      <div style="text-align:center; margin-bottom:24px;">
        <div style="font-size:24px; font-weight:600; color:#1f2937; margin-bottom:8px;">
          Sửa thông tin người dùng
        </div>
        <div style="color:#6b7280; font-size:15px;" id="editUserName"></div>
      </div>

      <div style="margin-bottom:20px;">
        <label style="display:block; margin-bottom:8px; font-weight:500; color:#4b5563;">Email</label>
        <input type="email" id="editEmail" 
               style="width:100%; padding:10px 12px; border:1px solid #e5e7eb; border-radius:8px; font-size:15px;"
               placeholder="Nhập email">
      </div>

      <div style="margin-bottom:20px;">
        <label style="display:block; margin-bottom:8px; font-weight:500; color:#4b5563;">Số điện thoại</label>
        <input type="tel" id="editPhone" 
               style="width:100%; padding:10px 12px; border:1px solid #e5e7eb; border-radius:8px; font-size:15px;"
               placeholder="Nhập số điện thoại">
      </div>

      <input type="hidden" id="editUserId">

      <div style="text-align:center;">
        <button onclick="saveUserEdit()" class="nav-btn" style="width:100%; margin:0;">
          Lưu thay đổi
        </button>
      </div>
    </div>
  </div>

  <!-- Modal xóa admin -->
  <div id="deleteAdminModal" class="modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; 
       background:rgba(0,0,0,0.5); backdrop-filter:blur(4px); z-index:1050;">
    <div class="modal-content" style="background:#fff; width:90%; max-width:450px; margin:100px auto; padding:32px; 
         border-radius:12px; box-shadow:0 20px 25px -5px rgba(0,0,0,0.1); position:relative;">
      <span class="close" onclick="closeDeleteAdminModal()" 
            style="position:absolute; right:16px; top:16px; font-size:24px; cursor:pointer; color:#6b7280;">&times;</span>
      
      <div style="text-align:center; margin-bottom:24px;">
        <div style="font-size:24px; font-weight:600; color:#dc2626; margin-bottom:8px;">
          Xác nhận xóa tài khoản quản trị
        </div>
        <div style="color:#6b7280; font-size:15px;" id="deleteAdminConfirmText"></div>
      </div>

      <div style="margin-bottom:20px;">
        <label style="display:block; margin-bottom:8px; font-weight:500; color:#4b5563;">
          Nhập mật khẩu của bạn để xác nhận
        </label>
        <input type="password" id="deleteAdminPassword" 
               style="width:100%; padding:10px 12px; border:1px solid #e5e7eb; border-radius:8px; font-size:15px;"
               placeholder="Nhập mật khẩu">
        <div id="deleteAdminPasswordError" style="color:#dc2626; font-size:14px; margin-top:6px; display:none;">
          Mật khẩu không đúng
        </div>
      </div>

      <input type="hidden" id="deleteAdminUserId">

      <div style="text-align:center;">
        <button onclick="confirmDeleteAdmin()" class="nav-btn btn-danger" style="width:100%; margin:0;">
          Xác nhận xóa
        </button>
      </div>
    </div>
  </div>

  <script>
    function openEditModal(userId, username, email, phone) {
      document.getElementById('editModal').style.display = 'block';
      document.getElementById('editUserId').value = userId;
      document.getElementById('editUserName').textContent = `Chỉnh sửa tài khoản "${username}"`;
      document.getElementById('editEmail').value = email !== 'Chưa cập nhật' ? email : '';
      document.getElementById('editPhone').value = phone || '';
    }

    function closeEditModal() {
      document.getElementById('editModal').style.display = 'none';
    }

    async function saveUserEdit() {
      const userId = document.getElementById('editUserId').value;
      const email = document.getElementById('editEmail').value;
      const phone = document.getElementById('editPhone').value;

      try {
        const response = await fetch('/quanly/nguoidung/sua/' + userId, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ email, phone })
        });

        const data = await response.json();
        
        if (data.success) {
          alert('Cập nhật thông tin thành công!');
          location.reload();
        } else {
          alert('Lỗi: ' + data.message);
        }
      } catch (error) {
        console.error('Lỗi:', error);
        alert('Có lỗi xảy ra khi cập nhật thông tin');
      }
    }

    function confirmDelete(userId, username) {
      if (confirm('Bạn có chắc muốn xóa tài khoản ' + username + '?')) {
        window.location.href = '/quanly/nguoidung/xoa/' + userId;
      }
    }

    function openDeleteAdminModal(userId, username) {
      document.getElementById('deleteAdminModal').style.display = 'block';
      document.getElementById('deleteAdminUserId').value = userId;
      document.getElementById('deleteAdminConfirmText').textContent = 
        `Bạn có chắc muốn xóa tài khoản quản trị "${username}"?`;
      document.getElementById('deleteAdminPassword').value = '';
      document.getElementById('deleteAdminPasswordError').style.display = 'none';
    }

    function closeDeleteAdminModal() {
      document.getElementById('deleteAdminModal').style.display = 'none';
    }

    async function confirmDeleteAdmin() {
      const userId = document.getElementById('deleteAdminUserId').value;
      const password = document.getElementById('deleteAdminPassword').value;

      if (!password) {
        alert('Vui lòng nhập mật khẩu để xác nhận');
        return;
      }

      try {
        const response = await fetch('/quanly/nguoidung/xoa/' + userId, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ password })
        });

        const data = await response.json();
        
        if (data.success) {
          alert('Xóa tài khoản quản trị thành công!');
          location.reload();
        } else {
          document.getElementById('deleteAdminPasswordError').style.display = 'block';
        }
      } catch (error) {
        console.error('Lỗi:', error);
        alert('Có lỗi xảy ra khi xóa tài khoản');
      }
    }

    // Đóng modal khi click ngoài
    window.onclick = function(event) {
      const editModal = document.getElementById('editModal');
      const deleteAdminModal = document.getElementById('deleteAdminModal');
      if (event.target == editModal) {
        closeEditModal();
      }
      if (event.target == deleteAdminModal) {
        closeDeleteAdminModal();
      }
    }
  </script>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</body>
</html>