<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Trang quản trị - myCARe</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body {
      background: #f4f6f9;
      font-family: Arial, sans-serif;
    }
    .container {
      margin-top: 80px;
      text-align: center;
    }
    h1 {
      margin-bottom: 40px;
      font-weight: bold;
      color: #333;
    }
    .btn-custom {
      width: 250px;
      margin: 15px;
      padding: 15px;
      font-size: 18px;
      border-radius: 12px;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Trang quản trị hệ thống</h1>

    <div>
      <a href="/quanly/diadiem" class="btn btn-primary btn-custom">
        Quản lý địa điểm
      </a>
      <a href="/quanly/nguoidung" class="btn btn-success btn-custom">
        Quản lý người dùng
      </a>
    </div>

    <div style="margin-top: 40px;">
      <a href="/" class="btn btn-secondary">Về trang chủ</a>
      <a href="/dangxuat" class="btn btn-danger">Đăng xuất</a>
    </div>
  </div>
</body>
</html>
