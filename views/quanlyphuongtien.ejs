<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>myCARe - Quản lý phương tiện của người dùng</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Modak&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { margin: 0; font-family: 'Arial', sans-serif; background: #f0f2f5; overflow: auto; }
    .left-panel { position: fixed; top: 0; left: 0; width: 320px; height: 100vh; background: #fff; z-index: 1002; border-right: 1px solid #e6e9ee; padding: 24px; box-shadow: 2px 0 8px rgba(15,23,42,0.04); }
    .left-panel .logo { font-family: 'Modak', cursive; font-size: 36px; background: linear-gradient(90deg, #1a73e8, #03f007); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: 3px; }
    .main-content { position: absolute; top: 0; left: 320px; width: calc(100% - 320px); height: 100vh; padding: 24px; display: flex; flex-direction: column; }
    .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
    .nav-btn { background: #1a73e8; border: none; padding: 10px 20px; margin: 0 8px; color: #fff; font-size: 15px; border-radius: 6px; cursor: pointer; transition: all 0.2s; text-decoration: none; }
    .card { width: 100%; max-width: 1100px; background: #fff; border-radius: 12px; box-shadow: 0 4px 16px rgba(17,24,39,0.05); overflow: hidden; }
    .card-header { background: #1a73e8; color: #fff; padding: 20px; font-size: 22px; font-weight: 600; }
    .card-body { padding: 20px; }
    .vehicle { border:1px solid #e6e9ee; border-radius:12px; padding:12px; display:flex; gap:12px; align-items:center; background:linear-gradient(180deg,#ffffff,#fbfdff); }
    .btn-primary { background: #1a73e8; color: #fff; border: none; padding: 8px 12px; border-radius: 8px; }
    .btn-edit { background:#f59e0b; color:#fff; border:none; padding:8px 12px; border-radius:8px; }
    .btn-delete { background:#dc2626; color:#fff; border:none; padding:8px 12px; border-radius:8px; }
    @media (max-width:900px) { .left-panel { display:none; } .main-content { left:0; width:100%; } }
  </style>
</head>
<body>
  <div class="left-panel">
    <div class="logo">myCARe</div>
    <a href="/quanly" class="nav-btn" style="display:block; margin-top:12px; text-decoration:none; text-align:left;">Quản lý</a>
    <a href="/quanly/nguoidung" class="nav-btn" style="display:block; margin-top:12px; text-decoration:none; text-align:left;">Quay lại danh sách người dùng</a>
  </div>

  <div class="main-content">
    <div class="top-bar">
      <div style="font-size:20px; font-weight:600; color:#0f172a;">Phương tiện của: <%= owner.tentaikhoan %> (ID: <%= owner.id %>)</div>
      <div>
        <a href="/quanly/nguoidung" class="nav-btn">Quay lại</a>
      </div>
    </div>

    <div style="display:flex; justify-content:center;">
      <div class="card">
        <div class="card-header">Danh sách phương tiện</div>
        <div class="card-body">
          <% if (vehicles && vehicles.length > 0) { %>
            <div style="display:flex; flex-direction:column; gap:12px;">
              <% vehicles.forEach(v => { %>
                <div class="vehicle">
                  <div style="width:80px; height:64px; background:#f8fafc; border-radius:8px; overflow:hidden; display:flex; align-items:center; justify-content:center;">
                    <% if (v.hinh_anh_xe) { %>
                      <img src="<%= v.hinh_anh_xe %>" style="width:100%; height:100%; object-fit:cover;" />
                    <% } else { %>
                      <div style="color:#9ca3af; font-size:12px;">No Image</div>
                    <% } %>
                  </div>
                  <div style="flex:1; min-width:0;">
                    <div style="font-weight:600; color:#0f172a; font-size:15px;"><%= v.bien_so %></div>
                    <div style="color:#6b7280; font-size:13px; margin-top:4px;"><%= v.hang_xe || 'Chưa xác định' %> · <%= v.dong_xe || '-' %></div>
                  </div>
                  <div style="display:flex; gap:8px; flex-wrap:wrap;">
                    <button class="btn-primary" style="text-decoration:none;" onclick="showPackages(<%= v.id %>)">Thông tin gói dịch vụ</button>
                    <button class="btn-primary" style="background: #8b5cf6;" onclick="location.href='/quanlythongke?id_nguoidung=<%= owner.id %>&id_xe=<%= v.id %>'" title="Thống kê">
                      <i class="bi bi-graph-up"></i> Thống kê
                    </button>
                    <button class="btn-edit" onclick="openEdit(<%= v.id %>, '<%= v.bien_so %>', '<%= (v.hang_xe||'') %>', '<%= (v.dong_xe||'') %>')">Sửa</button>
                    <form action="/quanly/nguoidung/<%= owner.id %>/phuongtien/xoa/<%= v.id %>" method="POST" onsubmit="return confirm('Xác nhận xóa phương tiện <%= v.bien_so %>?');">
                      <button type="submit" class="btn-delete">Xóa</button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div style="text-align:center; padding:36px; color:#374151;">
              <div style="font-size:18px; font-weight:600; margin-bottom:8px;">Người dùng chưa có phương tiện nào</div>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal chỉnh sửa (admin) -->
  <div id="editModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); justify-content:center; align-items:center; z-index:2000;">
    <div style="background:#fff; padding:20px; border-radius:12px; width:92%; max-width:480px;">
      <div style="font-size:18px; font-weight:600; margin-bottom:12px;">Sửa phương tiện</div>
      <form id="editForm" method="POST" enctype="multipart/form-data">
        <div style="margin-bottom:10px;">
          <label style="display:block; font-weight:500; color:#4b5563; margin-bottom:6px;">Biển số</label>
          <input name="bien_so" id="edit_bien" style="width:100%; padding:8px; border:1px solid #e5e7eb; border-radius:8px;" required />
        </div>
        <div style="margin-bottom:10px;">
          <label style="display:block; font-weight:500; color:#4b5563; margin-bottom:6px;">Hãng</label>
          <input name="hang_xe" id="edit_hang" style="width:100%; padding:8px; border:1px solid #e5e7eb; border-radius:8px;" />
        </div>
        <div style="margin-bottom:10px;">
          <label style="display:block; font-weight:500; color:#4b5563; margin-bottom:6px;">Dòng</label>
          <input name="dong_xe" id="edit_dong" style="width:100%; padding:8px; border:1px solid #e5e7eb; border-radius:8px;" />
        </div>
        <div style="margin-bottom:10px;">
          <label style="display:block; font-weight:500; color:#4b5563; margin-bottom:6px;">Ảnh (tùy chọn)</label>
          <input type="file" name="hinh_anh_xe" accept="image/*" />
        </div>
        <div style="display:flex; justify-content:flex-end; gap:8px;">
          <button type="button" onclick="closeEdit()" class="nav-btn" style="background:#6b7280;">Hủy</button>
          <button type="submit" class="btn-primary">Lưu</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal hiển thị gói chu kỳ (Bootstrap) -->
  <div class="modal fade" id="packagesModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Danh sách gói chu kỳ</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body" id="packagesContent">
          <div class="text-muted">Đang tải...</div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    function openEdit(id, bien, hang, dong) {
      document.getElementById('edit_bien').value = bien || '';
      document.getElementById('edit_hang').value = hang || '';
      document.getElementById('edit_dong').value = dong || '';
      const form = document.getElementById('editForm');
      form.action = '/quanly/nguoidung/<%= owner.id %>/phuongtien/sua/' + id;
      document.getElementById('editModal').style.display = 'flex';
    }
    function closeEdit() { document.getElementById('editModal').style.display = 'none'; }
    window.onclick = function(e) { const m = document.getElementById('editModal'); if (e.target == m) closeEdit(); };
    
    async function showPackages(vehicleId) {
      const content = document.getElementById('packagesContent');
      content.innerHTML = '<div class="text-muted">Đang tải...</div>';
      try {
        const res = await fetch('/api/bao_duong/' + vehicleId);
        if (!res.ok) throw new Error('Lỗi khi lấy dữ liệu');
        const data = await res.json();
        if (!Array.isArray(data) || data.length === 0) {
          content.innerHTML = '<div class="text-muted">Chưa có gói chu kỳ nào cho phương tiện này.</div>';
        } else {
          const rows = data.slice().sort((a,b)=> (b.id||0)-(a.id||0)).map(p=>{
            const ngayTh = p.ngay_thuc_hien ? p.ngay_thuc_hien.slice(0,10) : '-';
            const ngayHet = p.ngay_het_han ? p.ngay_het_han.slice(0,10) : '-';
            const label = p.loai === 'bao_duong' ? 'Bảo dưỡng' : 'Đăng kiểm';
            const status = p.trang_thai === 'con_han' ? '<span class="badge bg-success">Còn hạn</span>' : (p.trang_thai === 'sap_het_han' ? '<span class="badge bg-warning text-dark">Sắp hết hạn</span>' : '<span class="badge bg-danger">Hết hạn</span>');
            return `
              <div class="d-flex justify-content-between align-items-start" style="padding:12px; border-bottom:1px solid #eef2ff;">
                <div>
                  <div style="font-weight:600">${label} ${status}</div>
                  <div class="text-muted" style="font-size:13px;">Thực hiện: ${ngayTh} · Chu kỳ: ${p.chu_ky_thang} tháng · Hết hạn: ${ngayHet}</div>
                  ${p.ghi_chu ? `<div style="margin-top:6px; color:#374151">Ghi chú: ${p.ghi_chu}</div>` : ''}
                </div>
                <div class="btn-group" role="group">
                  <button class="btn btn-sm btn-outline-secondary" onclick="openEditPackage(${p.id}, ${vehicleId})">Cập nhật</button>
                  <button class="btn btn-sm btn-outline-danger" onclick="deletePackage(${p.id}, ${vehicleId})">Xóa</button>
                </div>
              </div>`;
          }).join('');
          content.innerHTML = rows;
        }
        const pkgModal = new bootstrap.Modal(document.getElementById('packagesModal'));
        pkgModal.show();
      } catch (err) {
        console.error(err);
        content.innerHTML = '<div class="text-danger">Không thể tải dữ liệu</div>';
        const pkgModal = new bootstrap.Modal(document.getElementById('packagesModal'));
        pkgModal.show();
      }
    }

    // helper actions used in modal
    async function deletePackage(pkgId, vehicleId) {
      if (!confirm('Xác nhận xóa gói?')) return;
      try {
        const res = await fetch('/api/bao_duong/' + pkgId, { method: 'DELETE' });
        if (!res.ok) { alert('Xóa thất bại'); return; }
        await showPackages(vehicleId);
      } catch (err) { console.error(err); alert('Lỗi'); }
    }

    // open edit modal and save via PUT
    async function openEditPackage(pkgId, vehicleId) {
      try {
        const res = await fetch('/api/bao_duong/' + vehicleId);
        if (!res.ok) throw new Error('Không lấy được dữ liệu gói');
        const data = await res.json();
        const p = data.find(x=>x.id===pkgId);
        if (!p) { alert('Không tìm thấy gói'); return; }
        const modalId = 'editPkgModal';
        const existing = document.getElementById(modalId);
        if (existing) existing.remove();
        const ngay = p.ngay_thuc_hien ? p.ngay_thuc_hien.slice(0,10) : '';
        const [y,mo,d] = ngay.split('-');
        const days = [...Array(31)].map((_,i)=>`<option value="${i+1}" ${d===(String(i+1).padStart(2,'0'))?'selected':''}>${i+1}</option>`).join('');
        const months = [...Array(12)].map((_,i)=>`<option value="${i+1}" ${mo===(String(i+1).padStart(2,'0'))?'selected':''}>${i+1}</option>`).join('');
        const currentYear = new Date().getFullYear();
        const years = [...Array(21)].map((_,i)=>`<option value="${currentYear-5+i}" ${String(currentYear-5+i)===String(y)?'selected':''}>${currentYear-5+i}</option>`).join('');
        const html = `
          <div class="modal fade" id="${modalId}" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
              <div class="modal-content">
                <div class="modal-header">
                  <h5 class="modal-title">Cập nhật gói chu kỳ</h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                  <form id="editPkgForm">
                    <div class="mb-3">
                      <label class="form-label">Loại</label>
                      <select class="form-select" name="loai" required>
                        <option value="bao_duong" ${p.loai==='bao_duong'?'selected':''}>Bảo dưỡng</option>
                        <option value="dang_kiem" ${p.loai==='dang_kiem'?'selected':''}>Đăng kiểm</option>
                      </select>
                    </div>
                    <div class="mb-3">
                      <label class="form-label">Ngày thực hiện</label>
                      <div class="d-flex gap-2">
                        <select class="form-select" name="day" style="width:30%">${days}</select>
                        <select class="form-select" name="month" style="width:30%">${months}</select>
                        <select class="form-select" name="year" style="width:40%">${years}</select>
                      </div>
                    </div>
                    <div class="mb-3">
                      <label class="form-label">Chu kỳ (tháng)</label>
                      <select class="form-select" name="chu_ky_thang" required>
                        ${[...Array(12)].map((_,i)=>`<option value="${i+1}" ${p.chu_ky_thang===(i+1)?'selected':''}>${i+1} tháng</option>`).join('')}
                      </select>
                    </div>
                    <div class="mb-3">
                      <label class="form-label">Ghi chú (tùy chọn)</label>
                      <textarea class="form-control" name="ghi_chu" rows="2">${p.ghi_chu || ''}</textarea>
                    </div>
                  </form>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                  <button id="savePkgEdit" type="button" class="btn btn-primary">Lưu</button>
                </div>
              </div>
            </div>
          </div>`;
        document.body.insertAdjacentHTML('beforeend', html);
        const el = document.getElementById(modalId);
        const modalInstance = new bootstrap.Modal(el);
        modalInstance.show();
        document.getElementById('savePkgEdit').addEventListener('click', async ()=>{
          const form = document.getElementById('editPkgForm');
          const fd = new FormData(form);
          const day = String(fd.get('day')).padStart(2,'0');
          const month = String(fd.get('month')).padStart(2,'0');
          const year = String(fd.get('year'));
          if (!/^[0-9]{4}$/.test(year)) { alert('Năm phải gồm 4 chữ số'); return; }
          const ngay_thuc_hien = `${year}-${month}-${day}`;
          const body = {
            loai: fd.get('loai'),
            ngay_thuc_hien,
            chu_ky_thang: fd.get('chu_ky_thang'),
            ghi_chu: fd.get('ghi_chu')
          };
          try {
            const res = await fetch('/api/bao_duong/' + pkgId, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
            if (!res.ok) { const err = await res.json().catch(()=>({error:'Lỗi'})); alert(err.error || 'Cập nhật thất bại'); return; }
            await showPackages(vehicleId);
            const bs = bootstrap.Modal.getInstance(el);
            if (bs) bs.hide();
          } catch (err) { console.error(err); alert('Lỗi khi cập nhật gói'); }
        });
      } catch (err) {
        console.error(err);
        alert('Không thể mở form sửa gói');
      }
    }
  </script>

</body>
</html>
